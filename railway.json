{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/",
    "healthcheckPort": 3000
  },
  "services": [
    {
      "serviceName": "web",
      "source": {
        "type": "dockerfile",
        "dockerfile": "Dockerfile"
      },
      "environment": "production",
      "port": 3000,
      "healthcheck": {
        "path": "/",
        "port": 3000
      }
    }
  ]
}